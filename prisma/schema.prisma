generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                    String                 @id @default(cuid())
  name                  String
  gender                String?
  birthYear             Int?
  phone                 String?
  profileImageUrl       String?
  aiFrontImageUrl       String?
  aiSideImageUrl        String?
  aiBackImageUrl        String?
  aiFrontImageUrlsJson  String?
  aiSideImageUrlsJson   String?
  aiBackImageUrlsJson   String?
  aiPhotoConsent        Boolean                @default(false)
  memo                  String?
  deletedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  hairProfile           HairProfile?
  preference            Preference?
  visits                Visit[]
  styleSuggestions      StyleSuggestion[]
  courseRecommendations CourseRecommendation[]
  contactLogs           ContactLog[]
  appointments          Appointment[]
  serviceSales          ServiceSale[]
  proposalResponses     ProposalResponse[]
}

model HairProfile {
  id                 String   @id @default(cuid())
  customerId         String   @unique
  hairThickness      String?
  hairVolume         String?
  hairTexture        String?
  scalpCondition     String?
  faceShape          String?
  forehead           String?
  lifestyle          String?
  stylingTimeMinutes Int?
  updatedAt          DateTime @updatedAt
  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Preference {
  id               String   @id @default(cuid())
  customerId       String   @unique
  preferredLength  String?
  preferredStyle   String?
  dislikes         String?
  colorPreference  String?
  maintenanceLevel String?
  referenceNotes   String?
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Visit {
  id                    String                 @id @default(cuid())
  customerId            String
  visitedAt             DateTime
  stylistName           String?
  requestedStyle        String?
  performedStyle        String?
  cutNotes              String?
  colorNotes            String?
  permNotes             String?
  customerReaction      String?
  nextRecommendation    String?
  customer              Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  styleSuggestions      StyleSuggestion[]
  courseRecommendations CourseRecommendation[]

  @@index([customerId, visitedAt])
}

model StyleSuggestion {
  id                 String   @id @default(cuid())
  customerId         String
  visitId            String?
  suggestedStyleName String
  reason             String?
  caution            String?
  stylingAdvice      String?
  imageUrls          String[] @default([])
  imageUrlsJson      String?
  menuSuggestion     String?
  estimatedMinutes   Int?
  maintenanceLevel   String?
  label              String?
  faceAnalysis       String?
  imagePrompt        String?
  accepted           Boolean  @default(false)
  archivedAt         DateTime?
  createdAt          DateTime @default(now())
  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  visit              Visit?   @relation(fields: [visitId], references: [id], onDelete: SetNull)
  proposalResponses  ProposalResponse[]

  @@index([customerId, createdAt])
}

model CourseRecommendation {
  id               String   @id @default(uuid())
  customerId       String
  visitId          String?
  title            String
  reason           String
  caution          String?
  estimatedMinutes Int?
  estimatedPrice   Int?
  priority         String?
  accepted         Boolean  @default(false)
  createdAt        DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  visit    Visit?   @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([visitId])
}

model ContactLog {
  id                String   @id @default(cuid())
  customerId        String
  channel           String
  purpose           String?
  message           String
  outcome           String?
  nextAction        String?
  scheduledFollowUp DateTime?
  createdAt         DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([scheduledFollowUp])
}

model Appointment {
  id              String   @id @default(cuid())
  customerId      String
  scheduledAt     DateTime
  menu            String?
  estimatedPrice  Int?
  status          String   @default("仮予約")
  source          String?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceSales ServiceSale[]

  @@index([customerId, scheduledAt])
  @@index([scheduledAt])
}

model ServiceSale {
  id            String   @id @default(cuid())
  customerId    String
  appointmentId String?
  title         String
  amount        Int
  paymentMethod String?
  paidAt        DateTime @default(now())
  source        String?
  note          String?
  createdAt     DateTime @default(now())

  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([customerId, paidAt])
  @@index([appointmentId])
  @@index([paidAt])
}

model ProposalResponse {
  id            String   @id @default(cuid())
  suggestionId  String
  customerId    String
  intent        String
  preferredDate DateTime?
  message       String?
  contactName   String?
  contactPhone  String?
  status        String   @default("未対応")
  createdAt     DateTime @default(now())

  suggestion StyleSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([suggestionId, createdAt])
  @@index([customerId, createdAt])
  @@index([status])
}
